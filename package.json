{
  "name": "movie-haven",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "check": "biome check .",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "db:push": "pnpm --filter @movie-haven/db push",
    "db:generate": "pnpm --filter @movie-haven/db generate",
    "db:migrate": "pnpm --filter @movie-haven/db migrate",
    "db:studio": "pnpm --filter @movie-haven/db studio",
    "okf:build": "pnpm --filter @movie-haven/api okf:build",
    "okf:validate": "python3 \"$OKF_CONVERT\" validate --bundle docs/okf",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^4.1.10",
    "turbo": "^2.4.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "shell-quote": ">=1.8.4",
      "fast-uri": ">=3.1.2"
    }
  }
}
