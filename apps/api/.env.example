# Postgres connection string.
# Local: docker (pnpm infra:up). Prod: Neon POOLED connection string (must include ?sslmode=require).
DATABASE_URL=postgresql://postgres:password@localhost:5432/movie_haven

# Redis connection string.
# Local: docker. Prod: Upstash TLS URL (starts with rediss://).
REDIS_URL=redis://localhost:6379

# Auth secret for signing/verifying JWTs.
# MUST be byte-for-byte identical to apps/web/.env.local JWT_SECRET.
JWT_SECRET=replace_me_with_a_long_random_secret

# TMDB API v4 read access token — required at startup, server won't boot without it.
# Get one at https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=your_tmdb_v4_read_access_token

# Comma-separated list of allowed CORS origins.
# Prod: your deployed web URL, e.g. https://movie-haven.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Local dev port. In production, Render/host injects PORT and this is ignored.
API_PORT=3001
NODE_ENV=development
