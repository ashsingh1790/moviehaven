# URL of the API server (no trailing slash).
# Local: http://localhost:3001. Prod: your Render service URL, e.g. https://movie-haven-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth secret for verifying JWTs in middleware.
# MUST be byte-for-byte identical to apps/api JWT_SECRET.
JWT_SECRET=replace_me_with_a_long_random_secret
